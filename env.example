# Vyrona — environment variables
# Copy this file to ".env" and fill in your own Supabase project credentials.
# Get these from: Supabase Dashboard -> Project Settings -> API
#
# NEVER commit your real ".env" file. It is already listed in .gitignore.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Optional: app name shown in a few places (defaults to "Vyrona")
VITE_APP_NAME=Vyrona
